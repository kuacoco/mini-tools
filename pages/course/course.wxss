/* ---------- 可爱清新风格：马卡龙薄荷 + 淡粉 + 淡紫 ---------- */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.course-page {
  position: relative;
  flex: 1;
  min-height: 0;
  background: linear-gradient(
    180deg,
    #f0fdf9 0%,
    #ecfeff 40%,
    #fdf2f8 80%,
    #ffffff 100%
  );
  box-sizing: border-box;
}

.month-swiper {
  height: 100%;
  min-height: 0;
}

.month-content {
  height: 100%;
  overflow-y: auto;
  padding: 28rpx 28rpx 140rpx;
  box-sizing: border-box;
}

.month-header {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 24rpx;
}

.month-row {
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.month-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #5d5d6b;
  letter-spacing: 0.5rpx;
}

.month-switch {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #e0f2fe;
  display: flex;
  align-items: center;
  justify-content: center;
}

.month-switch-icon {
  width: 32rpx;
  height: 32rpx;
}

.today-btn {
  font-size: 24rpx;
  color: #0d9488;
  background: #ccfbf1;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-weight: 500;
}

.selected-date-bar {
  position: relative;
  text-align: center;
  padding: 12rpx 0 24rpx;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  height: 40rpx;
}

.selected-date-bar::before {
  content: "";
  width: 6rpx;
  height: 28rpx;
  background: #0d9488;
  border-radius: 4rpx;
  margin: 10rpx;
}

.selected-date-value {
  font-size: 32rpx;
  font-weight: 500;
  color: #6b7280;
  margin-right: 10rpx;
}

.calendar-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow:
    0 8rpx 32rpx rgba(45, 212, 191, 0.06),
    0 4rpx 16rpx rgba(244, 114, 182, 0.04);
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.calendar-header {
  display: flex;
  margin-bottom: 12rpx;
}

.calendar-weekday {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 500;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
}

.calendar-day {
  width: 14.28%;
  height: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  position: relative;
  box-sizing: border-box;
}

.calendar-day.other-month .day-number {
  color: #cbd5e1;
}

.calendar-day.is-today .day-number {
  background: linear-gradient(145deg, #5eead4 0%, #2dd4bf 100%);
  color: #fff;
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(45, 212, 191, 0.35);
}

.calendar-day.is-selected .day-number {
  background: #f5f3ff;
  color: #7c3aed;
  border: 3rpx solid #c4b5fd;
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
}

.calendar-day.is-selected.is-today .day-number {
  background: linear-gradient(145deg, #5eead4 0%, #2dd4bf 100%);
  color: #fff;
  border: 3rpx solid #99f6e4;
  box-shadow: 0 4rpx 12rpx rgba(45, 212, 191, 0.35);
}

.day-number {
  font-size: 26rpx;
  color: #64748b;
  flex-shrink: 0;
}

.checkin-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #f9a8d4 0%, #f472b6 100%);
  flex-shrink: 0;
  box-shadow: 0 2rpx 6rpx rgba(244, 114, 182, 0.35);
  position: absolute;
  transform: translateY(30rpx);
}

.course-list-content {
  padding-bottom: 40rpx;
}

.empty-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  padding: 56rpx 28rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 8rpx 28rpx rgba(45, 212, 191, 0.06);
}

.empty-title {
  display: block;
  font-size: 30rpx;
  color: #5d5d6b;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #94a3b8;
}

.swipe-row {
  position: relative;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.swipe-action {
  position: absolute;
  top: 0;
  width: 164rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.swipe-action.edit {
  left: 0;
  background: linear-gradient(145deg, #67e8f9 0%, #22d3ee 100%);
}

.swipe-action.delete {
  right: 0;
  background: linear-gradient(145deg, #f9a8d4 0%, #f472b6 100%);
}

.course-item {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow:
    0 8rpx 28rpx rgba(45, 212, 191, 0.06),
    0 2rpx 12rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  transition: transform 0.18s ease;
}

/* 当日已打卡的卡片：纯色置灰，不透明 */
