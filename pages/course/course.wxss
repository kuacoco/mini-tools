.item-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.course-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  transition: all 0.3s ease;
}

.course-avatar.checked {
  /* background: linear-gradient(145deg, #f9a8d4 0%, #f472b6 100%) !important;
  box-shadow: 0 2rpx 6rpx rgba(244, 114, 182, 0.35); */
}

.avatar-char {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

.avatar-check {
  font-size: 44rpx;
  font-weight: 600;
  color: #fff;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-header {
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 30rpx;
  color: #5d5d6b;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.item-subtitle {
  font-size: 24rpx;
  color: #94a3b8;
}

.progress-track {
  width: 100%;
  height: 18rpx;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.25s ease-out;
}

.fab-wrap {
  position: fixed;
  right: 40rpx;
  bottom: 46rpx;
  z-index: 997;
}

.add-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #5eead4 0%, #2dd4bf 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 36rpx rgba(45, 212, 191, 0.45);
  transition:
    transform 180ms ease,
    box-shadow 180ms ease;
}

.add-btn:active {
  transform: scale(1.05);
}

.add-btn-icon {
  width: 40rpx;
  height: 40rpx;
}

/* ---------- 新增/编辑课程弹窗 ---------- */
.popup-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(148, 163, 184, 0.25);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}

.popup-sheet {
  width: 100%;
  max-height: 75vh;
  background: linear-gradient(180deg, #f0fdf9 0%, #fdf2f8 50%, #ffffff 100%);
  border-radius: 36rpx 36rpx 0 0;
  padding: 0 32rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  transform-origin: bottom center;
  box-shadow:
    0 -12rpx 48rpx rgba(45, 212, 191, 0.08),
    0 -4rpx 24rpx rgba(244, 114, 182, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
}

.popup-mask.is-entering {
  animation: maskFadeIn 220ms ease-out forwards;
}

.popup-mask.is-entering .popup-sheet {
  animation: sheetSlideUp 280ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.popup-mask.is-leaving {
  animation: maskFadeOut 220ms ease-out forwards;
}

.popup-mask.is-leaving .popup-sheet {
  animation: sheetSlideDown 240ms cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

@keyframes maskFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes sheetSlideUp {
  from {
    opacity: 0;
    transform: translateY(60rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes maskFadeOut {
  from {
    opacity: 1;
  }
  to {
    opacity: 0;
  }
}

@keyframes sheetSlideDown {
  from {
    opacity: 1;
    transform: translateY(0);
  }
  to {
    opacity: 0;
    transform: translateY(60rpx);
  }
}

.popup-handle {
  width: 80rpx;
  height: 10rpx;
  border-radius: 5rpx;
  background: #c4b5fd;
  margin: 20rpx auto 16rpx;
  opacity: 0.7;
}

.popup-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0 24rpx;
  border-bottom: 1rpx solid rgba(196, 181, 253, 0.25);
}

.popup-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #5d5d6b;
  letter-spacing: 0.5rpx;
}

.popup-close {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f5f3ff;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(196, 181, 253, 0.3);
}

.popup-close-icon {
  width: 40rpx;
  height: 40rpx;
}

.popup-body {
  padding: 28rpx 0 24rpx;
}

.popup-field {
  margin-bottom: 28rpx;
}

.popup-field:last-of-type {
  margin-bottom: 0;
}

.popup-label {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.popup-input {
  width: 100%;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid #e9d5ff;
  border-radius: 20rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #5d5d6b;
  box-sizing: border-box;
  transition:
    border-color 0.2s ease,
    box-shadow 0.2s ease;
}

.popup-input:focus {
  border-color: #c4b5fd;
  box-shadow: 0 0 0 4rpx rgba(196, 181, 253, 0.2);
}

.stepper-row {
  display: flex;
  align-items: center;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid #e9d5ff;
  border-radius: 20rpx;
  overflow: hidden;
  transition: border-color 0.2s ease;
}

.stepper-row:focus-within {
  border-color: #c4b5fd;
  box-shadow: 0 0 0 4rpx rgba(196, 181, 253, 0.2);
}

.stepper-btn {
  width: 96rpx;
  height: 100%;
  background: #f5f3ff;
  color: #7c3aed;
  font-size: 40rpx;
  font-weight: 400;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition:
    background 0.15s ease,
    color 0.15s ease;
}

.stepper-btn:active {
  background: #ede9fe;
}

.stepper-btn.disabled {
  background: #faf5ff;
  color: #c4b5fd;
}

.stepper-input {
  flex: 1;
  height: 100%;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #5d5d6b;
  padding: 0 16rpx;
  background: transparent;
}

.popup-footer {
  padding: 24rpx 0 0;
}

.popup-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  transition:
    transform 0.15s ease,
    opacity 0.15s ease;
}

.popup-btn.primary {
  background: linear-gradient(145deg, #5eead4 0%, #2dd4bf 100%);
  color: #fff;
  box-shadow: 0 8rpx 28rpx rgba(45, 212, 191, 0.4);
}

.popup-btn.primary:active {
  transform: scale(0.98);
  opacity: 0.95;
}
