page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.location-page {
  flex: 1;
  min-height: 0;
  background: linear-gradient(180deg, #f5f5f5 0%, #fff 100%);
  padding: 32rpx;
  box-sizing: border-box;
}

.content-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.label {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.value {
  font-size: 36rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 28rpx;
  word-break: break-all;
}

.value-last {
  margin-bottom: 0;
}

.error-msg {
  font-size: 26rpx;
  color: #c95b51;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.btn-row {
  display: flex;
}

.btn + .btn {
  margin-left: 24rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  padding: 0;
  margin: 0;
}

/* 主按钮：复制 */
.btn-copy {
  background: #c95b51;
  color: #fff;
}

.btn-copy[disabled] {
  background: #e0e0e0;
  color: #999;
}

/* 次按钮：刷新，与主按钮统一为实心风格 */
.btn-refresh {
  background: #f5f5f5;
  color: #c95b51;
  border: 2rpx solid #c95b51;
}
