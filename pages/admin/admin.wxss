.admin-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f0f7 0%, #e8f0f8 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200rpx;
  color: #888;
  font-size: 28rpx;
}

.admin-content {
  padding-bottom: 40rpx;
}

.config-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.add-btn {
  font-size: 28rpx;
  color: #d06d7f;
  padding: 8rpx 16rpx;
}

/* 飞笛配置列表 */
.config-list {
  margin-top: 8rpx;
}

.config-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.config-row:last-child {
  border-bottom: none;
}

.config-info {
  flex: 1;
  min-width: 0;
}

.config-userId {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.config-preview {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.config-action {
  padding: 12rpx 24rpx;
  color: #d06d7f;
  font-size: 28rpx;
}

.config-item {
  margin-bottom: 24rpx;
}

.config-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.config-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  background: #f7f7f7;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #d06d7f 0%, #b86dd0 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 16rpx;
}

.save-btn.is-disabled {
  opacity: 0.6;
}

.save-btn::after {
  border: none;
}

/* 白名单列表 */
.empty-tip {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}

.whitelist-list {
  margin-top: 8rpx;
}

.whitelist-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.whitelist-item:last-child {
  border-bottom: none;
}

.whitelist-info {
  flex: 1;
  min-width: 0;
}

.whitelist-name {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.whitelist-openid {
  display: block;
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.whitelist-action {
  padding: 12rpx 24rpx;
  color: #d06d7f;
  font-size: 28rpx;
}

/* 弹窗 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.popup-content {
  width: 90%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 32rpx;
}

.popup-item {
  margin-bottom: 24rpx;
}

.popup-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.popup-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.popup-textarea {
  width: 100%;
  min-height: 100rpx;
  padding: 16rpx 20rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.popup-btn.is-disabled {
  opacity: 0.6;
}

.popup-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.popup-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 30rpx;
}

.popup-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.popup-btn.confirm {
  background: linear-gradient(135deg, #d06d7f 0%, #b86dd0 100%);
  color: #fff;
}

/* 同步操作 */
.sync-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.sync-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #8fb6f9 0%, #7fcad1 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
}

.sync-btn.is-disabled {
  opacity: 0.6;
}

.sync-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}