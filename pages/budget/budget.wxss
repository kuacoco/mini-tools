page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.budget-page {
  position: relative;
  flex: 1;
  min-height: 0;
  background: linear-gradient(180deg, #fff8f9 0%, #f7f8ff 55%, #ffffff 100%);
  box-sizing: border-box;
}

.budget-scroll {
  height: 100%;
  min-height: 0;
}

.budget-sticky-header {
  padding: 28rpx 28rpx 0;
  box-sizing: border-box;
}

.budget-list-content {
  padding: 0 28rpx 140rpx;
  box-sizing: border-box;
}

.summary-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 10rpx 36rpx rgba(69, 57, 113, 0.08);
  margin-bottom: 24rpx;
}

.month-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.month-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #2f3152;
}

.month-switch {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #f1f0ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.month-switch-icon {
  width: 36rpx;
  height: 36rpx;
}

.summary-grid {
  display: flex;
  justify-content: space-between;
}

.summary-item {
  display: flex;
  flex-direction: column;
}

.summary-label {
  font-size: 24rpx;
  color: #9697a8;
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 30rpx;
  color: #2f3152;
  font-weight: 600;
}

.empty-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 48rpx 28rpx;
  text-align: center;
  color: #9192a3;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  color: #4a4d67;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 24rpx;
}

.swipe-row {
  position: relative;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.swipe-action {
  position: absolute;
  top: 0;
  width: 164rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.swipe-action.edit {
  left: 0;
  background: linear-gradient(135deg, #8fb6f9 0%, #7fcad1 100%);
}

.swipe-action.delete {
  right: 0;
  background: linear-gradient(135deg, #f4a7b9 0%, #d06d7f 100%);
}

.budget-item {
  position: relative;
  background: #fff;
  border-radius: 20rpx;
  padding: 26rpx;
  box-shadow: 0 8rpx 24rpx rgba(41, 51, 89, 0.08);
  transition: transform 0.18s ease;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.item-name {
  font-size: 30rpx;
  color: #34364f;
  font-weight: 600;
}

.item-percent {
  font-size: 26rpx;
  color: #6f718a;
}

.amount-row {
  font-size: 24rpx;
  color: #888aa2;
  margin-bottom: 14rpx;
}

.progress-track {
  width: 100%;
  height: 18rpx;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.25s ease-out;
}

.remain-row {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #62647f;
}

.remain-row.over {
  color: #d06d7f;
}

.fab-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(21, 23, 39, 0.18);
  z-index: 996;
}

.fab-mask.is-entering {
  animation: maskFadeIn 180ms ease-out forwards;
}

.fab-mask.is-leaving {
  animation: maskFadeOut 160ms ease-in forwards;
}

.fab-wrap {
  position: fixed;
  right: 40rpx;
  bottom: 46rpx;
  z-index: 997;
}

.fab-menu {
  position: absolute;
  right: 0;
  bottom: 116rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  align-items: flex-end;
  transform-origin: right bottom;
}

.fab-menu.is-entering {
  animation: fabMenuIn 200ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.fab-menu.is-leaving {
  animation: fabMenuOut 160ms cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.fab-menu-item {
  min-width: 176rpx;
  height: 68rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 10rpx 24rpx rgba(55, 45, 94, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #3f4160;
  font-size: 26rpx;
  font-weight: 600;
}

.add-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f4a7b9 0%, #b6a3f3 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(123, 97, 182, 0.35);
  transition: transform 180ms ease, box-shadow 180ms ease;
}

.add-btn.is-active {
  transform: rotate(45deg) scale(1.03);
  box-shadow: 0 16rpx 30rpx rgba(123, 97, 182, 0.42);
}

.add-btn-icon {
  width: 40rpx;
  height: 40rpx;
}

@keyframes fabMenuIn {
  from {
    opacity: 0;
    transform: translateY(14rpx) scale(0.94);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes fabMenuOut {
  from {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  to {
    opacity: 0;
    transform: translateY(14rpx) scale(0.94);
  }
}

.popup-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(28, 30, 45, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}

.popup-sheet {
  width: 100%;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  transform-origin: bottom center;
}

.popup-mask.is-entering {
  animation: maskFadeIn 220ms ease-out forwards;
}

.popup-mask.is-entering .popup-sheet {
  animation: sheetSlideUp 240ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.popup-mask.is-leaving {
  animation: maskFadeOut 220ms ease-out forwards;
}

.popup-mask.is-leaving .popup-sheet {
  animation: sheetSlideDown 240ms cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

@keyframes maskFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes sheetSlideUp {
  from {
    opacity: 0;
    transform: translateY(42rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes maskFadeOut {
  from {
    opacity: 1;
  }
  to {
    opacity: 0;
  }
}

@keyframes sheetSlideDown {
  from {
    opacity: 1;
    transform: translateY(0);
  }
  to {
    opacity: 0;
    transform: translateY(42rpx);
  }
}

.popup-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #30334f;
}

.popup-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 56rpx;
  font-size: 40rpx;
  color: #7a7d97;
  background: #f3f4fd;
}

.popup-content {
  padding-top: 4rpx;
}

.popup-item {
  margin-bottom: 16rpx;
}

.popup-label {
  display: block;
  font-size: 24rpx;
  color: #616481;
  margin-bottom: 8rpx;
}

.popup-input {
  background: #f5f6ff;
  border-radius: 14rpx;
  padding: 20rpx;
  font-size: 30rpx;
  color: #30334f;
}

.popup-save {
  margin-top: 12rpx;
  height: 84rpx;
  line-height: 84rpx;
  border: none;
  border-radius: 42rpx;
  background: linear-gradient(135deg, #f4a7b9 0%, #b6a3f3 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.used-meta {
  margin-bottom: 14rpx;
}

.used-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #3a3d5e;
}

.used-total {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #8a8da7;
}

.used-input {
  background: #f4f5ff;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  font-size: 42rpx;
  color: #2f3152;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.calc-formula {
  margin-top: -6rpx;
  margin-bottom: 14rpx;
  padding: 0 4rpx;
  color: #8a8da7;
  font-size: 22rpx;
  line-height: 1.5;
}

